<Window x:Class="CheckerWPF.Views.LoginWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="EquipmentChecker — Đăng nhập"
        Width="420" Height="480"
        WindowStartupLocation="CenterScreen"
        ResizeMode="NoResize">
    <Grid Background="{StaticResource SurfaceBrush}">
        <Border Style="{StaticResource Card}"
                Width="340" VerticalAlignment="Center"
                HorizontalAlignment="Center">
            <StackPanel>
                <!-- Logo / title -->
                <TextBlock Text="EquipmentChecker"
                           FontSize="22" FontWeight="SemiBold"
                           Foreground="{StaticResource PrimaryBrush}"
                           HorizontalAlignment="Center" Margin="0,0,0,4"/>
                <TextBlock Text="Hệ thống giám sát thiết bị"
                           FontSize="12" Foreground="#888"
                           HorizontalAlignment="Center" Margin="0,0,0,28"/>

                <!-- Username -->
                <TextBlock Text="Username" FontSize="12" Margin="0,0,0,4"/>
                <TextBox Text="{Binding Username, UpdateSourceTrigger=PropertyChanged}"
                         FontSize="14" Padding="10,8" Margin="0,0,0,14"/>

                <!-- Password -->
                <TextBlock Text="Password" FontSize="12" Margin="0,0,0,4"/>
                <PasswordBox x:Name="PwdBox"
                             FontSize="14" Padding="10,8" Margin="0,0,0,8"
                             PasswordChanged="PwdBox_PasswordChanged"/>

                <!-- Error -->
                <TextBlock Text="{Binding ErrorMessage}"
                           Foreground="{StaticResource DangerBrush}"
                           FontSize="12" TextWrapping="Wrap"
                           Margin="0,0,0,12"
                           Visibility="{Binding ErrorMessage,
                               Converter={StaticResource StringToVisibilityConverter}}"/>

                <!-- Login button -->
                <Button Content="Đăng nhập"
                        Command="{Binding LoginCommand}"
                        Style="{StaticResource PrimaryBtn}"
                        Height="40" FontSize="14"/>

                <!-- Loading -->
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Center"
                            Margin="0,12,0,0"
                            Visibility="{Binding IsLoading,
                                Converter={StaticResource BoolToVisibilityConverter}}">
                    <ProgressBar IsIndeterminate="True" Width="120" Height="4"
                                 Foreground="{StaticResource PrimaryBrush}"/>
                </StackPanel>
            </StackPanel>
        </Border>
    </Grid>
</Window>
